# ============================================
# Hasu ML - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!
# ============================================

# ============================================
# Database Configuration
# ============================================

# PostgreSQL (OLTP)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=retail_db
POSTGRES_USER=retail_user
POSTGRES_PASSWORD=change_me_secure_password

# ClickHouse (Data Warehouse)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=retail_dw
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change_me_secure_password

# Redis (Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# Airflow Configuration
# ============================================
AIRFLOW_UID=1000
AIRFLOW_GID=0
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW_WEBSERVER_PORT=8085

# ============================================
# Superset Configuration
# ============================================
SUPERSET_SECRET_KEY=your-secret-key-here-min-24-chars-long
SUPERSET_DB_USER=superset
SUPERSET_DB_PASSWORD=superset
SUPERSET_DB_NAME=superset
SUPERSET_PORT=8088
MAPBOX_API_KEY=

# ============================================
# ML Pipeline Configuration
# ============================================

# Email notifications
EMAIL_SENDER=ml-pipeline@company.com
EMAIL_PASSWORD=
EMAIL_TRAINING_REPORT=team@company.com
EMAIL_FORECAST_REPORT=team@company.com
EMAIL_ERROR_ALERT=admin@company.com

# Model training settings
MODEL_RETRAIN_INTERVAL_DAYS=7
FORECAST_HORIZON_DAYS=30
ML_TRIALS=50
ML_CV_SPLITS=3
ML_RANDOM_STATE=42

# ============================================
# Sync Tool Configuration
# ============================================
SYNC_BATCH_SIZE=10000
SYNC_INTERVAL_MINUTES=5

# ============================================
# Docker/K8s Configuration
# ============================================

# Container resources
MODEL_DIR=/app/models
LOG_LEVEL=INFO

# K8s namespace (optional)
NAMESPACE=hasu-ml

# ============================================
# Optional: MSSQL Configuration
# ============================================
# MSSQL_HOST=localhost
# MSSQL_PORT=1433
# MSSQL_DB=retail_dw
# MSSQL_USER=sa
# MSSQL_PASSWORD=change_me_secure_password
