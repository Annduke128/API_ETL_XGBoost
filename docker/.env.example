# ============================================
# Retail Data Pipeline - Environment Configuration
# ============================================
# Copy this file to .env and modify values as needed
# ============================================

# ============================================
# Database Configuration
# ============================================

# PostgreSQL (OLTP)
POSTGRES_USER=retail_user
POSTGRES_PASSWORD=retail_password
POSTGRES_DB=retail_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ClickHouse (Data Warehouse)
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse_password
CLICKHOUSE_DB=retail_dw

# Redis (Cache)
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================
# Airflow Configuration
# ============================================
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@airflow-postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW_WEBSERVER_PORT=8085

# ============================================
# Superset Configuration
# ============================================
SUPERSET_SECRET_KEY=thisisasecretkeyforretailsuperset123
SUPERSET_DB_USER=superset
SUPERSET_DB_PASSWORD=superset
SUPERSET_DB_NAME=superset
SUPERSET_PORT=8088

# ============================================
# ML Pipeline Configuration
# ============================================

# Email notifications
EMAIL_SENDER=ml-pipeline@company.com
EMAIL_PASSWORD=
EMAIL_TRAINING_REPORT=team@company.com
EMAIL_FORECAST_REPORT=team@company.com
EMAIL_ERROR_ALERT=admin@company.com

# Model training
MODEL_RETRAIN_INTERVAL_DAYS=7
FORECAST_HORIZON_DAYS=30

# ============================================
# Sync Tool Configuration
# ============================================
SYNC_BATCH_SIZE=10000
SYNC_INTERVAL_MINUTES=5

